<Window x:Class="ExcelParser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Excel Parser - Импорт показаний счетчиков" 
        Height="500" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Выбор файла -->
        <GroupBox Grid.Row="0" Header="Excel файл" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtFilePath" Grid.Column="0" Margin="0,5,10,5" 
                         IsReadOnly="True" VerticalContentAlignment="Center"/>
                <Button x:Name="BtnSelectFile" Grid.Column="1" Content="Обзор..." 
                        Click="BtnSelectFile_Click" Margin="0,5,0,5"/>
            </Grid>
        </GroupBox>

        <!-- Строка подключения -->
        <GroupBox Grid.Row="1" Header="Подключение к SQL Server" Margin="0,0,0,10">
            <TextBox x:Name="TxtConnectionString" Margin="0,5" 
                     Text="Server=localhost;Database=YourDatabase;Trusted_Connection=True;TrustServerCertificate=True;"
                     VerticalContentAlignment="Center"/>
        </GroupBox>

        <!-- Кнопка обработки -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BtnParseAndGenerate" Grid.Column="0" 
                    Content="📊 Парсить Excel и выполнить INSERT в SQL" 
                    Click="BtnParseAndGenerate_Click" 
                    FontSize="14" Padding="10,5" Height="40"/>
            <Button x:Name="BtnCopySql" Grid.Column="1" Content="📋 Копировать отчет" 
                    Click="BtnCopySql_Click" Margin="10,0,0,0" Height="40"/>
        </Grid>

        <!-- Статус -->
        <TextBlock x:Name="LblStatus" Grid.Row="3" Text="Ожидание..." 
                   FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Вывод SQL/отчета -->
        <GroupBox Grid.Row="4" Header="Результат обработки">
            <TextBox x:Name="TxtSqlOutput" Margin="0,5" 
                     TextWrapping="Wrap" AcceptsReturn="True" 
                     VerticalScrollBarVisibility="Auto" 
                     FontFamily="Consolas" FontSize="12"/>
        </GroupBox>

        <!-- Подсказка -->
        <TextBlock Grid.Row="5" Margin="0,10,0,0" TextWrapping="Wrap" FontStyle="Italic" Foreground="Gray">
            Ожидаемые колонки в Excel: "ГВС преды", "ГВС конеч", "ХВС преды". 
            Номер квартиры должен быть в первой колонке.
        </TextBlock>
    </Grid>
</Window>
